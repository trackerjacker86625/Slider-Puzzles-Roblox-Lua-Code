---------------------------------------------------------------------
-- TIMER
---------------------------------------------------------------------
local function stopTimer()
	timerRunning = false
end

local function startTimer()
	if timerRunning then return end
	timerRunning = true

	local startTime = tick() - elapsedTime  -- preserves paused time

	task.spawn(function()
		while timerRunning do
			-- compute total elapsed time based on real clock
			elapsedTime = tick() - startTime

			local totalSeconds = math.floor(elapsedTime)
			local minutes = math.floor(totalSeconds / 60)
			local seconds = totalSeconds % 60
			local milliseconds = math.floor((elapsedTime - totalSeconds) * 1000)

			timerLabel.Text = string.format("Time: %d:%02d.%03d", minutes, seconds, milliseconds)

			task.wait(0.01)
		end
	end)
end

---------------------------------------------------------------------
-- TILE LOCK / UNLOCK
---------------------------------------------------------------------
local function lockTiles()
	for _, tile in ipairs(tileOrder) do
		tile.Active = false
		tile.AutoButtonColor = false
	end
end

local function unlockTiles()
	for _, tile in ipairs(tileOrder) do
		tile.Active = true
		tile.AutoButtonColor = false
	end
end

