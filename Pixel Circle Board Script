---------------------------------------------------------------------
-- PUZZLE HELPERS
---------------------------------------------------------------------
local function updateTilePositions(tileW, tileH)
	for tile, rc in pairs(tileRC) do
		local r = rc[1]
		local c = rc[2]
		tile.Position = UDim2.fromOffset((c - 1) * tileW, (r - 1) * tileH)
	end
end
local function getTileIndex(tile)
	return tileIndex[tile]
end

local function findEmptyIndex()
	for i, tile in ipairs(tileOrder) do
		if correctIndexMap[tile] == #tileOrder then
			return i
		end
	end
end

local function isSolved()
	for i = #tileOrder - 1, 1, -1 do
		if correctIndexMap[tileOrder[i]] ~= i then
			return false
		end
	end
	return true
end

local function getNeighborsRC(r, c, vDiam, hDiam)
	local neighbors = {}

	local function addIfValid(rr, cc)
		if rr >= 1 and rr <= vDiam and cc >= 1 and cc <= hDiam then
			if maskGrid[rr] and maskGrid[rr][cc] and tileGrid[rr] and tileGrid[rr][cc] then
				table.insert(neighbors, {r = rr, c = cc})
			end
		end
	end

	addIfValid(r - 1, c)
	addIfValid(r + 1, c)
	addIfValid(r, c - 1)
	addIfValid(r, c + 1)

	return neighbors
end

local function swapTilesLogicalRC(r1, c1, r2, c2)
	local t1 = tileGrid[r1][c1]
	local t2 = tileGrid[r2][c2]

	-- swap in grid
	tileGrid[r1][c1], tileGrid[r2][c2] = t2, t1

	-- swap RC lookup
	tileRC[t1], tileRC[t2] = tileRC[t2], tileRC[t1]

	-- swap in tileOrder
	local i1 = tileIndex[t1]
	local i2 = tileIndex[t2]
	tileOrder[i1], tileOrder[i2] = tileOrder[i2], tileOrder[i1]
	tileIndex[t1], tileIndex[t2] = i2, i1

	-- VISUAL UPDATE
	updateTilePositions(TILE_WIDTH, TILE_HEIGHT)
end
local function applyLayoutOrders()
	for i, tile in ipairs(tileOrder) do
		tile.LayoutOrder = i
	end
end

-- Multi-tile slide along row/col, respecting mask
local function slideTilesCircle(clickedTile, vDiam, hDiam)
	local emptyTile = tileOrder[emptyIndex]
	local rcEmpty = tileRC[emptyTile]
	local rcClick = tileRC[clickedTile]
	if not rcEmpty or not rcClick then return 0 end

	local er, ec = rcEmpty[1], rcEmpty[2]
	local cr, cc = rcClick[1], rcClick[2]

	local dr = cr - er
	local dc = cc - ec

	-- must be same row or same column
	if dr ~= 0 and dc ~= 0 then
		return 0
	end

	local stepR = 0
	local stepC = 0
	if dr ~= 0 then
		stepR = (dr > 0) and 1 or -1
	elseif dc ~= 0 then
		stepC = (dc > 0) and 1 or -1
	else
		return 0
	end

	-- verify path is continuous through mask
	local path = {}
	local r, c = er, ec
	while r ~= cr or c ~= cc do
		r += stepR
		c += stepC
		if not (r >= 1 and r <= vDiam and c >= 1 and c <= hDiam) then
			return 0
		end
		if not (maskGrid[r] and maskGrid[r][c] and tileGrid[r] and tileGrid[r][c]) then
			return 0
		end
		table.insert(path, {r = r, c = c})
	end

	-- perform swaps from empty toward clicked
	for _, pos in ipairs(path) do
		swapTilesLogicalRC(er, ec, pos.r, pos.c)
		er, ec = pos.r, pos.c
	end

	-- update emptyIndex (blank tile is still last solved index)
	emptyIndex = findEmptyIndex()
	applyLayoutOrders()

	return #path
end
local function solvedRCFromIndex(index, vDiam, hDiam)
	local count = 0
	for r = 1, vDiam do
		for c = 1, hDiam do
			if maskGrid[r][c] then
				count += 1
				if count == index then
					return r, c
				end
			end
		end
	end
end
