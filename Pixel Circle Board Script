-----------------------
-- TILE PROCESSING
-----------------------
local function processTile(tile)
	if inputLocked then return end

	local v = vDiamValue.Value
	local h = hDiamValue.Value

	local index = getTileIndex(tile)
	if not index then return end

	local moved = slideTilesCircle(tile, v, h)
	if moved == 0 then return end

	moves += moved
	movesLabel.Text = "Moves: " .. moves

	if not timerRunning and moves > 0 then
		startTimer()
	end

	if isSolved() then
		stopTimer()
		inputLocked = true
		lockTiles()

		CirclePuzzleCompleted:FireServer(
			v,
			h,
			elapsedTime,
			moves,
			slidingUsedThisPuzzle,
			puzzleModeValue.Value
		)
	end
end
---------------------------------------------------------------------
-- BUILD CIRCLE PUZZLE
---------------------------------------------------------------------
local function buildCirclePuzzle(vDiam, hDiam)
	-- Clear old tiles
	for _, child in ipairs(board:GetChildren()) do
		if child:IsA("TextButton") then
			child:Destroy()
		end
	end

	tileOrder = {}
	tileIndex = {}
	correctIndexMap = {}
	tileGrid = {}
	tileRC = {}
	maskGrid = {}
	emptyIndex = 0

	-- Mask
	maskGrid = generateCircleMask(vDiam, hDiam)

	-- Count tiles
	local totalTiles = 0
	for r = 1, vDiam do
		for c = 1, hDiam do
			if maskGrid[r][c] then
				totalTiles += 1
			end
		end
	end

	-- Board size
	local camera = workspace.CurrentCamera
	local screenH = camera.ViewportSize.Y
	local scale = getPuzzleScale(settingsFrame.PuzzleSize.Value)
	local baseSize = screenH * scale

	local maxDiam = math.max(vDiam, hDiam)
	local tileSize = math.floor(baseSize / maxDiam)

	local boardW = tileSize * hDiam
	local boardH = tileSize * vDiam

	board.Size = UDim2.fromOffset(boardW, boardH)

	-- NOW tileW and tileH exist
	local tileW = tileSize
	local tileH = tileSize

	-- Store globally for updates
	TILE_WIDTH = tileW
	TILE_HEIGHT = tileH

	-- Find blank position (bottom-right existing tile)
	local emptyR, emptyC
	for r = vDiam, 1, -1 do
		for c = hDiam, 1, -1 do
			if maskGrid[r][c] then
				emptyR = r
				emptyC = c
				break
			end
		end
		if emptyR then break end
	end

	local textPaddingScale = getTextPaddingScale(settingsFrame.TextSize.Value)

	-- Create tiles
	local currentIndex = 0
	for r = 1, vDiam do
		tileGrid[r] = tileGrid[r] or {}
		for c = 1, hDiam do
			if maskGrid[r][c] then
				currentIndex += 1

				local tile = Instance.new("TextButton")
				tile.Name = "Tile" .. currentIndex
				tile.Parent = board
				tile.Size = UDim2.fromOffset(tileW, tileH)
				tile.Position = UDim2.fromOffset((c - 1) * tileW, (r - 1) * tileH)
				tile.TextScaled = true
				tile.Font = Enum.Font.GothamBold
				tile.BorderSizePixel = 0
				tile.AutoButtonColor = false
				tile.LayoutOrder = currentIndex

				tileGrid[r][c] = tile
				tileRC[tile] = {r, c}
				correctIndexMap[tile] = currentIndex
				tileOrder[currentIndex] = tile
				tileIndex[tile] = currentIndex

				if r == emptyR and c == emptyC then
					tile.Text = ""
					tile.BackgroundTransparency = 0
					tile.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
					tile.Active = false
				else
					if puzzleModeValue.Value == "Numbers" then
						tile.Text = tostring(currentIndex)

						local padding = Instance.new("UIPadding")
						padding.Parent = tile
						padding.PaddingTop = UDim.new(textPaddingScale, 0)
						padding.PaddingBottom = UDim.new(textPaddingScale, 0)
						padding.PaddingLeft = UDim.new(textPaddingScale, 0)
						padding.PaddingRight = UDim.new(textPaddingScale, 0)

						local mode = colorpatternMode.Value
						if mode == "Rows" then
							tile.BackgroundColor3 = getRowColor(r, vDiam)
						elseif mode == "Columns" then
							tile.BackgroundColor3 = getColumnColor(c, hDiam)
						else
							tile.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
						end

					elseif puzzleModeValue.Value == "Images"
						and selectedImageIdValue.Value ~= "" then

						tile.Text = ""
						tile.BackgroundColor3 = Color3.fromRGB(255, 255, 255)

						local img = Instance.new("ImageLabel")
						img.Parent = tile
						img.Size = UDim2.fromScale(1, 1)
						img.BackgroundTransparency = 1
						img.BorderSizePixel = 0
						img.Active = false
						img.Image = "rbxassetid://" .. selectedImageIdValue.Value

						local sliceW = 1024 / hDiam
						local sliceH = 1024 / vDiam

						img.ImageRectSize = Vector2.new(sliceW, sliceH)
						img.ImageRectOffset = Vector2.new(
							(c - 1) * sliceW,
							(r - 1) * sliceH
						)
					end
				end
			end
		end
	end

	emptyIndex = findEmptyIndex()

	-- INPUT EVENTS
	for _, tile in ipairs(tileOrder) do
		tile.MouseButton1Click:Connect(function()
			if slidingModeValue.Value then return end
			processTile(tile)
		end)

		tile.MouseEnter:Connect(function()
			if not slidingModeValue.Value then return end
			processTile(tile)
		end)
	end

	lockTiles()
end

---------------------------------------------------------------------
-- PERMUTATION PARITY
---------------------------------------------------------------------
local function permutationParity(tileOrder, correctIndexMap)
	local N = #tileOrder
	local visited = table.create(N, false)
	local cycles = 0

	for i = 1, N do
		if not visited[i] then
			cycles += 1
			local j = i
			while not visited[j] do
				visited[j] = true
				j = correctIndexMap[tileOrder[j]]
			end
		end
	end

	return (N - cycles) % 2
end


---------------------------------------------------------------------
-- BLANK DISTANCE PARITY (BFS on maskGrid)
---------------------------------------------------------------------
local function blankDistanceParity(vDiam, hDiam, blankR, blankC, goalR, goalC)
	local queue = { {blankR, blankC, 0} }
	local visited = {}
	visited[blankR .. "," .. blankC] = true

	local dirs = { {1,0},{-1,0},{0,1},{0,-1} }

	while #queue > 0 do
		local r, c, d = table.unpack(table.remove(queue, 1))

		if r == goalR and c == goalC then
			return d % 2
		end

		for _, dir in ipairs(dirs) do
			local rr = r + dir[1]
			local cc = c + dir[2]

			if maskGrid[rr] and maskGrid[rr][cc] then
				local key = rr .. "," .. cc
				if not visited[key] then
					visited[key] = true
					table.insert(queue, {rr, cc, d + 1})
				end
			end
		end
	end

	return nil  -- should never happen on a connected board
end


---------------------------------------------------------------------
-- FINAL SOLVABILITY TEST (Fix 2)
---------------------------------------------------------------------
local function isReachableState(vDiam, hDiam)
	local permParity = permutationParity(tileOrder, correctIndexMap)

	-- Find blank tile index in tileOrder
	local blankTile = nil
	local blankIndex = nil
	local solvedBlankIndex = #tileOrder

	for i, tile in ipairs(tileOrder) do
		if correctIndexMap[tile] == solvedBlankIndex then
			blankTile = tile
			blankIndex = i
			break
		end
	end

	-- Convert blankIndex ? current (r,c)
	local blankR, blankC = solvedRCFromIndex(blankIndex, vDiam, hDiam)

	-- Convert solved index ? goal (r,c)
	local goalIndex = correctIndexMap[blankTile]
	local goalR, goalC = solvedRCFromIndex(goalIndex, vDiam, hDiam)

	local distParity = blankDistanceParity(vDiam, hDiam, blankR, blankC, goalR, goalC)

	return permParity == distParity
end

---------------------------------------------------------------------
-- RESET TO SOLVED ORDER
---------------------------------------------------------------------
local function resetTileOrderToSolved()
	local N = #tileOrder
	local solved = table.create(N)

	for _, tile in ipairs(tileOrder) do
		local idx = correctIndexMap[tile]
		solved[idx] = tile
	end

	tileOrder = solved
end


---------------------------------------------------------------------
-- SHUFFLE (random permutation + solvability check)
---------------------------------------------------------------------
local function shuffleCirclePuzzle(vDiam, hDiam)
	inputLocked = true
	stopTimer()

	elapsedTime = 0
	timerLabel.Text = "Time: 0:00.00"
	moves = 0
	movesLabel.Text = "Moves: 0"

	unlockTiles()
	slidingUsedThisPuzzle = slidingModeValue.Value

	resetTileOrderToSolved()

	local rng = Random.new()
	local N = #tileOrder

	repeat
		resetTileOrderToSolved()

		for i = 1, N - 1 do
			local j = rng:NextInteger(i, N)
			tileOrder[i], tileOrder[j] = tileOrder[j], tileOrder[i]
		end
	until isReachableState(vDiam, hDiam)

	-- rebuild tileGrid, tileRC, tileIndex
	tileIndex = {}
	local idx = 1

	for r = 1, vDiam do
		for c = 1, hDiam do
			if maskGrid[r] and maskGrid[r][c] then
				local tile = tileOrder[idx]
				tileGrid[r][c] = tile
				tileRC[tile] = { r, c }
				tileIndex[tile] = idx
				idx += 1
			end
		end
	end

	emptyIndex = findEmptyIndex()
	inputLocked = false
	updateTilePositions(TILE_WIDTH, TILE_HEIGHT)
end
------------------------------
-- COLOR PATTERN CHANGE
------------------------------
colorpatternMode.Changed:Connect(function()
	local v = vDiamValue.Value
	local h = hDiamValue.Value
	local mode = colorpatternMode.Value

	for _, tile in ipairs(tileOrder) do
		if tile.Text ~= "" then
			local solvedIndex = correctIndexMap[tile]
			local sr, sc = solvedRCFromIndex(solvedIndex, v, h)

			if mode == "Rows" then
				tile.BackgroundColor3 = getRowColor(sr, v)
			elseif mode == "Columns" then
				tile.BackgroundColor3 = getColumnColor(sc, h)
			else
				tile.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
			end
		end
	end
end)

---------------------------------------------------------------------
-- REBUILD WHEN SETTINGS CHANGE
---------------------------------------------------------------------
local function rebuild()

	local v = vDiamValue.Value
	local h = hDiamValue.Value

	buildCirclePuzzle(v, h)

	-- Reset puzzle state
	inputLocked = true
	timerRunning = false
	elapsedTime = 0
	moves = 0

	timerLabel.Text = "Time: 0:00.00"
	movesLabel.Text = "Moves: 0"

	sizeLabel.Text = "Circle: " .. v .. "x" .. h
	statisticsSize.Text = "Circle " .. v .. "x" .. h
	leaderboardSize.Text = "Circle " .. v .. "x" .. h

	local key = tostring(v) .. "x" .. tostring(h)

	BestTimeLabel.Text = formatTime(savedBestTimes[key])
	LeastAmountofMovesLabel.Text = formatMoves(savedBestMoves[key])
end

vDiamValue.Changed:Connect(rebuild)
hDiamValue.Changed:Connect(rebuild)
puzzleModeValue.Changed:Connect(rebuild)
selectedImageIdValue.Changed:Connect(rebuild)

gui:GetPropertyChangedSignal("Enabled"):Connect(function()
	if gui.Enabled == false then
		rebuild()
	end
end)

---------------------------------------------------------------------
-- RELAYOUT ON SCREEN / SIZE CHANGES
---------------------------------------------------------------------
local function relayoutPuzzle()
	task.wait(0.05)

	local v = vDiamValue.Value
	local h = hDiamValue.Value

	-- Screen + scale
	local camera = workspace.CurrentCamera
	local screenH = camera.ViewportSize.Y
	local scale = getPuzzleScale(settingsFrame.PuzzleSize.Value)
	local baseSize = screenH * scale

	-- Compute tile size based on largest dimension
	local maxDiam = math.max(v, h)
	local tileSize = math.floor(baseSize / maxDiam)
	local boardSize = tileSize * maxDiam

	-- Resize board
	board.Size = UDim2.fromOffset(boardSize, boardSize)

	-- Update globals
	TILE_WIDTH = tileSize
	TILE_HEIGHT = tileSize

	-- Padding scale
	local textPaddingScale = getTextPaddingScale(settingsFrame.TextSize.Value)

	----------------------------------------------------------------------
	-- Resize + reposition all tiles
	----------------------------------------------------------------------
	for _, tile in ipairs(tileOrder) do
		local rc = tileRC[tile]
		local r, c = rc[1], rc[2]

		-- Resize tile
		tile.Size = UDim2.fromOffset(tileSize, tileSize)

		-- Reposition tile
		tile.Position = UDim2.fromOffset(
			(c - 1) * tileSize,
			(r - 1) * tileSize
		)

		-- Determine if this is an image tile
		local isImageTile = (tile.Text == "" and tile:FindFirstChildOfClass("ImageLabel") ~= nil)

		if not isImageTile then
			-- NUMBER TILE ? ensure padding exists
			local padding = tile:FindFirstChildOfClass("UIPadding")
			if not padding then
				padding = Instance.new("UIPadding")
				padding.Parent = tile
			end

			padding.PaddingTop = UDim.new(textPaddingScale, 0)
			padding.PaddingBottom = UDim.new(textPaddingScale, 0)
			padding.PaddingLeft = UDim.new(textPaddingScale, 0)
			padding.PaddingRight = UDim.new(textPaddingScale, 0)

		else
			-- IMAGE TILE ? remove padding
			local padding = tile:FindFirstChildOfClass("UIPadding")
			if padding then padding:Destroy() end
		end
	end
end

