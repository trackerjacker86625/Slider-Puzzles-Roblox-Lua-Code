local function getPuzzleScale(sizeName)
	if sizeName == "100%" then
		return 0.97
	elseif sizeName == "90%" then
		return 0.90
	elseif sizeName == "80%" then
		return 0.80
	elseif sizeName == "70%" then
		return 0.70
	elseif sizeName == "60%" then
		return 0.60
	elseif sizeName == "50%" then
		return 0.50
	elseif sizeName == "40%" then
		return 0.40
	end
	return 0.90 -- fallback
end
local function getTextPaddingScale(sizeName)
	if sizeName == "100%" then
		return 0
	elseif sizeName == "75%" then
		return 0.125
	elseif sizeName == "50%" then
		return 0.25
	elseif sizeName == "25%" then
		return 0.375
	end
	return 0
end

--------------------------
-- MASK GENERATION (CIRCLE)
--------------------------
local function generateCircleMask(vDiam, hDiam)
	local mask = {}

	for r = 1, vDiam do
		mask[r] = {}
		for c = 1, hDiam do
			mask[r][c] = false
		end
	end

	-- SPECIAL CASE: 4×4 circle only
	if vDiam == 4 and hDiam == 4 then
		mask = {
			{false, true,  true,  false},
			{true,  true,  true,  true },
			{true,  true,  true,  true },
			{false, true,  true,  false},
		}
	else
		-- ORIGINAL LOGIC FOR 5×5 AND LARGER
		local midR = math.floor((vDiam + 1) / 2)
		local midC = math.floor((hDiam + 1) / 2)

		-- Fill cross
		for c = 1, hDiam do mask[midR][c] = true end
		for r = 1, vDiam do mask[r][midC] = true end

		-- Build left-to-right top arc
		do
			local r = midR
			local c = 1

			while r > 1 do
				r -= 1
				mask[r][c] = true

				if c < midC then
					c += 1
					mask[r][c] = true
				end
			end

			while c < midC do
				c += 1
				mask[r][c] = true
			end
		end

		-- Build top-to-bottom left arc
		do
			local r = 1
			local c = midC

			while c > 1 do
				c -= 1
				mask[r][c] = true

				if r < midR then
					r += 1
					mask[r][c] = true
				end
			end

			while r < midR do
				r += 1
				mask[r][c] = true
			end
		end

		-- Mirror left arcs to right side
		for rr = 1, midR do
			for cc = 1, midC do
				if mask[rr][cc] then
					local mc = hDiam - cc + 1
					mask[rr][mc] = true
				end
			end
		end

		-- Mirror top half to bottom half
		for rr = 1, midR do
			for cc = 1, hDiam do
				if mask[rr][cc] then
					local mr = vDiam - rr + 1
					mask[mr][cc] = true
				end
			end
		end

		-- Fill interior
		for rr = 1, vDiam do
			local minC, maxC = nil, nil

			for cc = 1, hDiam do
				if mask[rr][cc] then
					minC = minC and math.min(minC, cc) or cc
					maxC = maxC and math.max(maxC, cc) or cc
				end
			end

			if minC and maxC then
				for cc = minC, maxC do
					mask[rr][cc] = true
				end
			end
		end

		-- REMOVE CORNERS WHEN ONE SIDE = 4
		if hDiam == 4 or vDiam == 4 then
			mask[1][1] = false
			mask[1][hDiam] = false
			mask[vDiam][1] = false
			mask[vDiam][hDiam] = false
		end
	end

	return mask
end
