local function formatTime(t)
	if not t then
		return "Best Time: --:--.--"
	end

	local total = math.floor(t)
	local minutes = math.floor(total / 60)
	local seconds = total % 60
	local centi = math.floor((t - total) * 100)

	return string.format("Best Time: %d:%02d.%02d", minutes, seconds, centi)
end

local function formatMoves(m)
	return m and ("Least Moves: " .. m) or "Least Moves: --"
end

local function getKey()
	return tostring(vDiamValue.Value) .. "x" .. tostring(hDiamValue.Value)
end

local function updateStats()
	local key = getKey()
	BestTimeLabel.Text = formatTime(savedBestTimes[key])
	LeastAmountofMovesLabel.Text = formatMoves(savedBestMoves[key])
end
